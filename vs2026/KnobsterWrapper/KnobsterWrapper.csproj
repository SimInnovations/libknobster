<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <KnobsterNativeBasePath>$(MSBuildProjectDirectory)\..\libknobster</KnobsterNativeBasePath>
    <KnobsterNativeDllPath>$(KnobsterNativeBasePath)\x64\libknobster.dll</KnobsterNativeDllPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(KnobsterNativeDllPath)" Link="libknobster.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

</Project>
